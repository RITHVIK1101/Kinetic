# Python YOLO26 server — your computer's local IP on the same WiFi as your iPhone
# Find your IP: run `ipconfig` in terminal and look for IPv4 under your WiFi adapter
# Or use an ngrok URL: ngrok http 8000
EXPO_PUBLIC_API_URL=http://192.168.x.x:8000

# Google AI (https://aistudio.google.com/app/apikey)
EXPO_PUBLIC_GOOGLE_AI_API_KEY=your_google_ai_api_key_here
EXPO_PUBLIC_GEMMA_MODEL_ID=gemma-4-vision

# ElevenLabs (https://elevenlabs.io/app/settings/api-keys)
EXPO_PUBLIC_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
